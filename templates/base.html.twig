<!DOCTYPE html>
<html lang="fr"
data-palette="{{ app.user ? app.user.palette: '' }}"
data-density="{{ app.user ? app.user.density: '' }}"
data-photo-filter="{{ app.user ? (app.user.photoFilter ? 'on' : 'off') : '' }}"
>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
        <title>{% block title %}Bingo{% endblock %} · Bingo</title>

        <meta name="description" content="{% block meta_description %}Carnet pastel de défis — coche tes cases, vise le bingo.{% endblock %}">
        <meta name="robots" content="{% block meta_robots %}noindex,nofollow{% endblock %}">
        {% block meta_canonical %}{% endblock %}

        {# Open Graph / Twitter #}
        <meta property="og:site_name" content="Bingo">
        <meta property="og:type" content="{% block og_type %}website{% endblock %}">
        <meta property="og:locale" content="fr_FR">
        <meta property="og:title" content="{% block og_title %}{{ block('title') }} · Bingo{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
        <meta property="og:image" content="{% block og_image %}{{ absolute_url('/pwa/icon-512.png') }}{% endblock %}">
        <meta property="og:url" content="{% block og_url %}{{ app.request.uri }}{% endblock %}">
        <meta name="twitter:card" content="summary">

        {# PWA #}
        <link rel="manifest" href="/manifest.json">
        <meta name="theme-color" content="#cdb4db" media="(prefers-color-scheme: light)">
        <meta name="theme-color" content="#cdb4db" media="(prefers-color-scheme: dark)">
        <meta name="apple-mobile-web-app-capable" content="yes">
        <meta name="apple-mobile-web-app-status-bar-style" content="default">
        <meta name="apple-mobile-web-app-title" content="Bingo">
        <link rel="apple-touch-icon" href="/pwa/apple-touch-icon.png">
        <link rel="icon" href="/logo.png">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet">
        <script>
            (function() {
                const h = document.documentElement;
                if (!h.dataset.palette) h.dataset.palette = localStorage.getItem('bingo.palette') || 'lavande';
                if (!h.dataset.density) h.dataset.density = localStorage.getItem('bingo.density') || 'regular';
                if (!h.dataset.photoFilter) h.dataset.photoFilter = localStorage.getItem('bingo.photoFilter') || 'on';
            })();
            // Capturé ici (et pas dans le controller Stimulus) car l'événement
            // peut tirer avant le chargement des modules ES de l'importmap.
            window.addEventListener('beforeinstallprompt', function (e) {
                e.preventDefault();
                window.deferredInstallPrompt = e;
                window.dispatchEvent(new CustomEvent('pwa:installable'));
            });
        </script>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body data-controller="pwa-update">
        {% block body %}{% endblock %}
        {% if app.user %}
            {{ include('components/_tweaks.html.twig') }}
        {% endif %}

        <div data-pwa-update-target="toast"
             class="pwa-toast hidden items-center gap-3 px-4 py-3 rounded-card bg-paper border border-line-soft text-[14px]">
            <span class="font-semibold text-ink">Nouvelle version disponible</span>
            <button type="button" data-action="pwa-update#reload" class="btn btn--primary btn--sm">Recharger</button>
            <button type="button" data-action="pwa-update#dismiss" aria-label="Ignorer" class="btn btn--ghost btn--icon btn--sm">×</button>
        </div>
    </body>
</html>
