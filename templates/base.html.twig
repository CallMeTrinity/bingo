<!DOCTYPE html>
<html lang="fr"
data-palette="{{ app.user ? app.user.palette: '' }}"
data-density="{{ app.user ? app.user.density: '' }}"
data-photo-filter="{{ app.user ? (app.user.photoFilter ? 'on' : 'off') : '' }}"
>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="/logo.png">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Caveat:wght@500;600;700&display=swap" rel="stylesheet">
        <script>
            (function() {
                const h = document.documentElement;
                if (!h.dataset.palette) h.dataset.palette = localStorage.getItem('bingo.palette') || 'lavande';
                if (!h.dataset.density) h.dataset.density = localStorage.getItem('bingo.density') || 'regular';
                if (!h.dataset.photoFilter) h.dataset.photoFilter = localStorage.getItem('bingo.photoFilter') || 'on';
            })();
        </script>
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {% block body %}{% endblock %}
        {% if app.user %}
            {{ include('components/_tweaks.html.twig') }}
        {% endif %}
    </body>
</html>
