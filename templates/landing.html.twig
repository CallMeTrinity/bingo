{% extends 'base.html.twig' %}

{% block title %}Bingo annuel — coche tes défis de l'année{% endblock %}
{% block meta_description %}Un carnet pastel pour transformer ton année en grille de défis. Crée ton bingo annuel, coche tes cases, vise les lignes.{% endblock %}
{% block meta_robots %}index,follow{% endblock %}
{% block meta_canonical %}<link rel="canonical" href="{{ url('app_home') }}">{% endblock %}

{% block body %}
    <header class="px-7 py-5 flex items-center justify-between max-w-6xl mx-auto">
        <a href="{{ path('app_home') }}" aria-label="Accueil" class="flex items-center gap-3">
            <span class="w-10 h-10 rounded-2xl bg-accent flex items-center justify-center font-serif text-[22px] text-ink shadow-[0_2px_6px_-2px_rgba(42,38,64,.18),0_1px_0_rgba(255,255,255,.5)_inset]">B</span>
            <span class="font-serif text-[20px]">Bingo annuel</span>
        </a>
        <nav class="flex items-center gap-2">
            <a href="{{ path('app_login') }}" class="btn btn--ghost btn--sm">Connexion</a>
            <a href="{{ path('app_register') }}" class="btn btn--primary btn--sm">Créer un compte</a>
        </nav>
    </header>

    <main class="max-w-6xl mx-auto px-7 pt-10 pb-24">
        <section class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <div>
                <div class="text-[11px] font-semibold tracking-widest uppercase text-ink-soft">Carnet pastel</div>
                <h1 class="font-serif text-[44px] sm:text-[56px] leading-[1.02] mt-2">
                    Une année,<br>
                    <span class="text-accent">une grille</span><br>
                    à remplir.
                </h1>
                <p class="font-hand text-[24px] text-ink-soft mt-5 -rotate-1">
                    <span class="text-accent">✦</span> Tes défis, en cases pastel.
                </p>
                <p class="text-ink-soft text-[16px] leading-relaxed mt-6 max-w-md">
                    Crée ton bingo annuel, note tes envies, coche au fil des mois.
                    Quand une ligne tombe, c'est la fête.
                </p>
                <div class="flex flex-wrap items-center gap-3 mt-8">
                    <a href="{{ path('app_register') }}" class="btn btn--primary btn--lg">
                        Créer mon bingo
                    </a>
                    <a href="{{ path('app_login') }}" class="btn btn--secondary btn--lg">
                        J'ai déjà un compte
                    </a>
                </div>
                <p class="text-[13px] text-ink-faint mt-5">
                    Gratuit, sans pub, sans tracker.
                </p>
            </div>

            <div class="relative">
                <div class="bg-paper border border-line-soft rounded-card-lg shadow-card p-6 rotate-1">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <div class="text-[11px] font-semibold tracking-widest uppercase text-ink-soft">Aperçu</div>
                            <div class="font-serif text-[20px]">Mon année 2026</div>
                        </div>
                        <div class="font-hand text-[18px] text-accent -rotate-3">3 / 16</div>
                    </div>
                    <div class="grid grid-cols-4 gap-2">
                        {% set previewItems = [
                            { label: 'Apprendre à coudre', done: true,  tone: 0 },
                            { label: 'Marathon',           done: false, tone: 1 },
                            { label: '3 nouveaux livres',  done: true,  tone: 2 },
                            { label: 'Week-end surprise',  done: false, tone: 3 },
                            { label: 'Cours de céramique', done: false, tone: 4 },
                            { label: 'Lever de soleil',    done: true,  tone: 0 },
                            { label: 'Concert en plein air', done: false, tone: 1 },
                            { label: 'Recette inédite',    done: false, tone: 2 },
                            { label: 'Randonnée',          done: false, tone: 3 },
                            { label: 'Visiter un musée',   done: false, tone: 4 },
                            { label: 'Échange linguistique', done: false, tone: 0 },
                            { label: 'Don bénévole',       done: false, tone: 1 },
                            { label: 'Nuit à la belle étoile', done: false, tone: 2 },
                            { label: 'Vélo 50km',          done: false, tone: 3 },
                            { label: 'Méditation 30j',     done: false, tone: 4 },
                            { label: 'Lettre à un proche', done: false, tone: 0 },
                        ] %}
                        {% for cell in previewItems %}
                            <div data-tone="{{ cell.tone }}"
                                 class="aspect-square rounded-xl border border-line-soft p-1.5 flex items-center justify-center text-center text-[10px] font-medium {{ cell.done ? 'bg-mint/50' : 'bg-cream/50' }} {{ cell.done ? 'text-ink' : 'text-ink-soft' }}">
                                <span class="line-clamp-3 leading-tight">{{ cell.label }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                <div class="hidden sm:block absolute -top-6 -right-4 font-hand text-[20px] text-ink-soft -rotate-6">
                    <span class="text-accent">↑</span> ta vraie année
                </div>
            </div>
        </section>

        <section class="mt-24 grid sm:grid-cols-3 gap-6">
            <article class="bg-paper border border-line-soft rounded-card-lg p-6 shadow-[0_2px_8px_-4px_rgba(42,38,64,.06)]">
                <div class="w-10 h-10 rounded-xl bg-lavender/60 mb-4"></div>
                <h2 class="font-serif text-[22px] leading-tight">Une grille par année</h2>
                <p class="text-ink-soft text-[14px] leading-relaxed mt-2">Choisis ta taille, glisse tes envies, mélange. Le bingo se range tout seul dans ton carnet.</p>
            </article>
            <article class="bg-paper border border-line-soft rounded-card-lg p-6 shadow-[0_2px_8px_-4px_rgba(42,38,64,.06)]">
                <div class="w-10 h-10 rounded-xl bg-peach/60 mb-4"></div>
                <h2 class="font-serif text-[22px] leading-tight">Photos &amp; notes</h2>
                <p class="text-ink-soft text-[14px] leading-relaxed mt-2">Garde un souvenir derrière chaque case cochée : une photo, une phrase, une date.</p>
            </article>
            <article class="bg-paper border border-line-soft rounded-card-lg p-6 shadow-[0_2px_8px_-4px_rgba(42,38,64,.06)]">
                <div class="w-10 h-10 rounded-xl bg-mint/60 mb-4"></div>
                <h2 class="font-serif text-[22px] leading-tight">Partage en lecture</h2>
                <p class="text-ink-soft text-[14px] leading-relaxed mt-2">Une URL publique en option, pour montrer ta progression sans révéler ton carnet.</p>
            </article>
        </section>

        <section class="mt-20 text-center">
            <p class="font-hand text-[24px] text-ink-soft -rotate-1 mb-5">
                <span class="text-accent">※</span> Prêt·e à commencer ?
            </p>
            <a href="{{ path('app_register') }}" class="btn btn--primary btn--lg">
                Créer mon premier bingo
            </a>
        </section>
    </main>

    <footer class="max-w-6xl mx-auto px-7 pb-10 text-[13px] text-ink-faint flex items-center justify-between">
        <span>© Bingo annuel</span>
        <span class="font-hand text-[16px]">fait avec soin</span>
    </footer>
{% endblock %}
