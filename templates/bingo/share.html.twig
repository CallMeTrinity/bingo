{% extends 'base.html.twig' %}

{% set ownerName = bingo.owner.displayName ?: bingo.owner.userIdentifier %}

{% block title %}{{ bingo.title }} · {{ bingo.year }} par {{ ownerName }}{% endblock %}

{% block meta_description %}Découvre « {{ bingo.title }} » — le bingo annuel de {{ ownerName }} pour {{ bingo.year }}. {{ bingo.bingoItems|length }} cases à coller, à cocher, à vivre.{% endblock %}

{% block meta_robots %}index,follow{% endblock %}

{% block meta_canonical %}<link rel="canonical" href="{{ url('bingo_share', { slug: bingo.slug }) }}">{% endblock %}

{% block og_type %}article{% endblock %}

{% set eyebrow = 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' %}

{% block body %}
    {% embed 'components/header.html.twig' %}
        {% block header_main %}
            {% set ownerName = bingo.owner.displayName ?: bingo.owner.userIdentifier %}
            <div class="{{ eyebrow }}">Bingo de {{ ownerName }} · {{ bingo.year }}</div>
            <h1 class="font-serif text-[26px] leading-tight mt-0.5">{{ bingo.title }}</h1>
        {% endblock %}

        {% block header_right %}
            <div data-controller="modal" class="flex items-center">
                <button type="button"
                        data-action="modal#open"
                        class="btn btn--secondary btn--sm">
                    Partager
                </button>
                {{ include('components/_share_panel.html.twig', { bingo: bingo }, with_context = false) }}
            </div>
        {% endblock %}
    {% endembed %}

    <main class="max-w-270 mx-auto px-7 pt-8 pb-20">
        {{ include('bingo/_grid.html.twig', { bingo: bingo, linePositions: linePositions, readOnly: true }) }}
    </main>
{% endblock %}
