{% extends 'base.html.twig' %}

{% block title %}Bingo {{ bingo.year }}{% endblock %}

{% block body %}

    <main>
        <h1>{{ bingo.title }} - {{ bingo.year }}</h1>

        <div class="bingo-grid">
            {% for item in bingo.bingoItems %}

                <div class="bingo-cell" data-controller="bingo-cell" data-bingo-cell-target="cell"
                     data-action="click->bingo-cell#mark">{{ item.label }}</div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
