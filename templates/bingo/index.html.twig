{% extends 'base.html.twig' %}

{% block title %}Bingo {{ bingo.year }}{% endblock %}

{% set pct = total > 0 ? (completed / total * 100) : 0 %}
{% set dash = total > 0 ? (completed / total * 97.4) : 0 %}
{% set eyebrow = 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' %}

{% block body %}
    <div data-controller="bingo-board modal"
         data-action="bingo-cell:updated->bingo-board#sync">

        {% embed 'components/header.html.twig' %}
            {% block header_main %}
                <div class="{{ eyebrow }}">{{ bingo.year }}</div>
                <h1 class="font-serif text-[26px] leading-tight mt-0.5">{{ bingo.title }}</h1>
            {% endblock %}

            {% block header_right %}
                <div class="flex items-center gap-3.5">
                    <div class="text-right">
                        <div class="{{ eyebrow }}">Avancement</div>
                        <div class="font-serif text-[22px]" data-bingo-board-target="progressFraction">
                            {{ completed }}<span class="text-ink-faint">/{{ total }}</span>
                        </div>
                    </div>
                    <div class="relative w-14 h-14">
                        <svg viewBox="0 0 36 36" width="56" height="56" class="-rotate-90">
                            <circle cx="18" cy="18" r="15.5" fill="none" stroke="var(--color-line)" stroke-width="3" />
                            <circle cx="18" cy="18" r="15.5" fill="none" stroke="var(--color-lavender)" stroke-width="3" stroke-linecap="round"
                                    data-bingo-board-target="progressRing"
                                    stroke-dasharray="{{ dash }} 97.4" />
                        </svg>
                        <div class="absolute inset-0 flex items-center justify-center text-[13px] font-semibold" data-bingo-board-target="progressLabel">{{ pct|round }}%</div>
                    </div>
                </div>
            {% endblock %}
        {% endembed %}

        <main class="max-w-270 mx-auto px-7 pt-8 pb-20">
            <section class="flex flex-wrap gap-3 mb-6">
                {% for chip in [
                    { label: 'Cases faites',     value: completed ~ '/' ~ total, swatch: 'bg-lavender', target: 'completedCount' },
                    { label: 'Lignes complètes', value: completedLinesCount,     swatch: 'bg-peach',    target: 'completedLines' },
                    { label: 'Reste à faire',    value: total - completed,       swatch: 'bg-mint',     target: 'remaining' },
                    { label: 'Année',            value: bingo.year,              swatch: 'bg-sky',      target: null },
                ] %}
                    <div class="flex items-center gap-2.5 px-3.5 py-2.5 bg-paper border border-line-soft rounded-xl shadow-[0_2px_6px_-2px_rgba(42,38,64,.05)]">
                        <div class="w-7 h-7 rounded-lg {{ chip.swatch }} shadow-[0_1px_0_rgba(255,255,255,.6)_inset]"></div>
                        <div>
                            <div class="{{ eyebrow }}">{{ chip.label }}</div>
                            <div class="font-serif text-xl leading-none"
                                {% if chip.target %}data-bingo-board-target="{{ chip.target }}"{% endif %}>
                                {{ chip.value }}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </section>

            <section class="relative bg-paper rounded-card-lg p-6 shadow-card border border-line-soft">
                <div class="absolute -top-3.5 left-7 px-3.5 py-1 rounded-full bg-lavender text-ink font-hand text-lg -rotate-3 shadow-[0_4px_12px_-4px_rgba(42,38,64,.18)]">
                    ✿ {{ bingo.title }}
                </div>

                <div class="grid gap-3" style="grid-template-columns: repeat({{ bingo.size }}, minmax(0, 1fr));">
                    {% for item in bingo.bingoItems %}
                        {{ include('bingo/_cell.html.twig', { item: item, linePositions: linePositions }, with_context = false) }}
                    {% endfor %}
                </div>
            </section>

            <p class="text-center mt-5 text-ink-soft text-[13px]">
                <span class="font-hand text-lg text-lavender mr-1">※</span>
                Clique sur une case pour la cocher
            </p>
        </main>

        <div class="fixed inset-0 pointer-events-none z-9999" data-bingo-board-target="confettiLayer"></div>

        {{ include('components/edit-bingo-item-modal.html.twig', with_context = false) }}
    </div>
{% endblock %}
