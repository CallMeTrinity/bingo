{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% set inputClass = 'px-3.5 py-2.5 rounded-xl bg-cream/60 border border-line-soft focus:outline-none focus:border-lavender focus:bg-paper text-ink placeholder:text-ink-faint transition-colors' %}
{% set labelClass = 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' %}

{% block body %}
    <main class="min-h-screen flex items-center justify-center px-5 py-10">
        <div class="w-full max-w-md">
            <a href="{{ path('app_home') }}" aria-label="Accueil"
               class="inline-flex w-12 h-12 mb-6 rounded-2xl bg-lavender items-center justify-center font-serif text-[26px] text-ink shadow-[0_2px_6px_-2px_rgba(42,38,64,.18),0_1px_0_rgba(255,255,255,.5)_inset] hover:-rotate-6 transition-transform">
                B
            </a>

            <div class="bg-paper border border-line-soft rounded-card-lg shadow-card p-7">
                <div class="mb-6">
                    <div class="{{ labelClass }}">Connexion</div>
                    <h1 class="font-serif text-[28px] leading-tight mt-0.5">Retour au carnet</h1>
                    <p class="font-hand text-[18px] text-ink-soft mt-1.5 -rotate-1">
                        <span class="text-lavender">✦</span> Reprends là où tu t'es arrêté.
                    </p>
                </div>

                {% if error %}
                    <div class="mb-4 px-4 py-3 rounded-xl border bg-rose-100 border-rose-200 text-rose-700 text-[14px] shadow-[0_2px_6px_-2px_rgba(42,38,64,.05)]">
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {% if app.user %}
                    <div class="mb-4 px-4 py-3 rounded-xl border bg-mint/40 border-mint text-ink text-[14px]">
                        Tu es déjà connecté en tant que <strong>{{ app.user.userIdentifier }}</strong>.
                        <a href="{{ path('app_logout') }}" class="text-lavender hover:underline">Se déconnecter</a>
                    </div>
                {% endif %}

                <form method="post" class="flex flex-col gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label for="username" class="{{ labelClass }}">Email</label>
                        <input type="email"
                               id="username"
                               name="_username"
                               value="{{ last_username }}"
                               autocomplete="email"
                               placeholder="toi@exemple.com"
                               required
                               autofocus
                               class="{{ inputClass }}">
                    </div>

                    <div class="flex flex-col gap-1.5">
                        <label for="password" class="{{ labelClass }}">Mot de passe</label>
                        <input type="password"
                               id="password"
                               name="_password"
                               autocomplete="current-password"
                               placeholder="••••••••"
                               required
                               class="{{ inputClass }}">
                    </div>

                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn btn--primary mt-2">
                        Se connecter
                    </button>
                </form>

                <p class="text-center text-[13px] text-ink-soft mt-5">
                    Pas encore de compte ?
                    <a href="{{ path('app_register') }}" class="text-lavender hover:underline">Créer un compte</a>
                </p>
            </div>
        </div>
    </main>
{% endblock %}
