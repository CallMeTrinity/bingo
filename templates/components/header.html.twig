<header class="sticky top-0 z-50 flex items-center gap-3 sm:gap-4 px-4 sm:px-7 py-4 sm:py-5 border-b border-line-soft bg-cream/70 backdrop-blur-md">
    <a href="{{ path(app.user ? 'app_dashboard' : 'app_home') }}" aria-label="Accueil"
       class="shrink-0 w-9.5 h-9.5 rounded-xl bg-accent flex items-center justify-center font-serif text-[22px] text-ink shadow-[0_2px_6px_-2px_rgba(42,38,64,.18),0_1px_0_rgba(255,255,255,.5)_inset] hover:-rotate-6 transition-transform duration-200">
        B
    </a>

    <div class="flex-1 min-w-0">
        {% block header_main %}{% endblock %}
    </div>

    {% block header_right %}{% endblock %}

    {% if app.user %}
        <div class="flex items-center gap-2.5 pl-2.5 sm:pl-3.5 border-l border-line-soft shrink-0">
            <span class="hidden md:inline text-[13px] font-semibold text-ink">{{ app.user.displayName }}</span>
            <a href="{{ path('app_logout') }}" class="btn btn--ghost btn--sm" aria-label="Déconnexion" title="Déconnexion">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span class="hidden md:inline">Déconnexion</span>
            </a>
        </div>
    {% else %}
        <a href="{{ path('app_login') }}" class="btn btn--secondary btn--sm">Connexion</a>
    {% endif %}
</header>
