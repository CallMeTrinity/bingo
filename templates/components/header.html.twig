<header class="sticky top-0 z-50 flex items-center gap-4 px-7 py-5 border-b border-line-soft bg-cream/70 backdrop-blur-md">
    <a href="{{ path('app_home') }}" aria-label="Accueil"
       class="w-9.5 h-9.5 rounded-xl bg-lavender flex items-center justify-center font-serif text-[22px] text-ink shadow-[0_2px_6px_-2px_rgba(42,38,64,.18),0_1px_0_rgba(255,255,255,.5)_inset] hover:-rotate-6 transition-transform duration-200">
        B
    </a>

    <div class="flex-1 min-w-0">
        {% block header_main %}{% endblock %}
    </div>

    {% block header_right %}{% endblock %}

    {% if app.user %}
        <div class="flex items-center gap-2.5 pl-3.5 border-l border-line-soft">
            <span class="text-[13px] font-semibold text-ink">{{ app.user.displayName }}</span>
            <a href="{{ path('app_logout') }}" class="btn btn--ghost btn--sm">Déconnexion</a>
        </div>
    {% else %}
        <a href="{{ path('app_login') }}" class="btn btn--secondary btn--sm">Connexion</a>
    {% endif %}
</header>
