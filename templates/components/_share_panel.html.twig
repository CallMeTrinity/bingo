{% set shareUrl = url('bingo_share', {slug: bingo.slug}) %}
{% set title = bingo.title %}
<dialog data-modal-target="dialog"
        data-action="click->modal#backdropClose"
        class="rounded-card-lg bg-paper border border-line-soft shadow-pop p-0 backdrop:bg-ink/40 backdrop:backdrop-blur-sm m-auto w-[min(92vw,460px)] open:animate-pop-in">

    <div class="relative p-7">
        <button type="button"
                data-action="modal#close"
                aria-label="Fermer"
                class="btn btn--secondary btn--icon absolute top-3.5 right-3.5">
            ×
        </button>

        <header class="mb-6">
            <div class="text-[11px] font-semibold tracking-widest uppercase text-ink-soft">Partage</div>
            <h2 class="font-serif text-[26px] leading-tight mt-0.5">{{ title }}</h2>
            <p class="font-hand text-[18px] text-ink-soft mt-1.5 -rotate-1">
                <span class="text-lavender">✦</span> Lecture seule pour qui reçoit le lien.
            </p>
        </header>

        <div data-controller="clipboard" data-clipboard-text-value="{{ shareUrl }}">
            <label class="block text-[13px] text-ink-soft mb-1.5">Lien public</label>
            <div class="flex gap-2 mb-2">
                <input type="text" readonly value="{{ shareUrl }}"
                       class="flex-1 px-3 py-2 rounded-xl border border-line-soft bg-cream/50 text-ink text-[13px]" />
                <button type="button" data-action="click->clipboard#copy" class="btn btn--primary">
                    Copier
                </button>
            </div>
            <span data-clipboard-target="feedback"
                  class="text-[12px] text-ink-soft opacity-0 transition-opacity">
                  ✓ Copié dans le presse-papiers
              </span>
        </div>

        <button disabled class="btn btn--secondary w-full mt-6">
            Télécharger en image (bientôt)
        </button>
    </div>
</dialog>
