{#
    Modal de création d'un nouveau bingo.
    Params:
      form: FormView for BingoType
#}
<dialog data-modal-target="dialog"
        data-action="click->modal#backdropClose"
        class="rounded-card-lg bg-paper border border-line-soft shadow-pop p-0 backdrop:bg-ink/40 backdrop:backdrop-blur-sm m-auto w-[min(92vw,460px)] open:animate-pop-in">

    <div class="relative p-7">
        <button type="button"
                data-action="modal#close"
                aria-label="Fermer"
                class="absolute top-3.5 right-3.5 w-9 h-9 rounded-full border border-line-soft bg-paper text-ink-soft hover:text-ink hover:bg-cream transition-colors flex items-center justify-center text-xl leading-none cursor-pointer">
            ×
        </button>

        <div class="mb-6">
            <div class="text-[11px] font-semibold tracking-widest uppercase text-ink-soft">Nouveau</div>
            <h2 class="font-serif text-[26px] leading-tight mt-0.5">Un nouveau bingo</h2>
            <p class="font-hand text-[18px] text-ink-soft mt-1.5 -rotate-1">
                <span class="text-lavender">✦</span> Seize cases à imaginer.
            </p>
        </div>

        {{ form_start(form, { attr: { class: 'flex flex-col gap-4', novalidate: 'novalidate' } }) }}

            <div class="flex flex-col gap-1.5">
                {{ form_label(form.title, null, { label_attr: { class: 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' } }) }}
                {{ form_widget(form.title, { attr: { class: 'px-3.5 py-2.5 rounded-xl bg-cream/60 border border-line-soft focus:outline-none focus:border-lavender focus:bg-paper text-ink placeholder:text-ink-faint transition-colors' } }) }}
                {{ form_errors(form.title, { attr: { class: 'text-[12px] text-rose-600' } }) }}
            </div>

            <div class="flex flex-col gap-1.5">
                {{ form_label(form.year, null, { label_attr: { class: 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' } }) }}
                {{ form_widget(form.year, { attr: { class: 'px-3.5 py-2.5 rounded-xl bg-cream/60 border border-line-soft focus:outline-none focus:border-lavender focus:bg-paper text-ink placeholder:text-ink-faint transition-colors w-32' } }) }}
                {{ form_errors(form.year, { attr: { class: 'text-[12px] text-rose-600' } }) }}
            </div>

            {{ form_errors(form) }}

            <div class="flex items-center justify-end gap-2.5 mt-2">
                <button type="button"
                        data-action="modal#close"
                        class="px-4 py-2.5 rounded-xl text-ink-soft hover:text-ink hover:bg-cream transition-colors cursor-pointer">
                    Annuler
                </button>
                <button type="submit"
                        class="px-4 py-2.5 rounded-xl bg-lavender text-ink font-semibold shadow-[0_1px_0_rgba(255,255,255,.6)_inset,0_4px_12px_-4px_rgba(42,38,64,.18)] hover:-translate-y-0.5 transition-transform cursor-pointer">
                    Créer le bingo
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</dialog>
