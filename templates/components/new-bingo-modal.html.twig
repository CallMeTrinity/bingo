{#
    Modal de création d'un nouveau bingo.
    Params:
      form: FormView for BingoType
#}
<dialog data-modal-target="dialog"
        data-action="click->modal#backdropClose"
        class="rounded-card-lg bg-paper border border-line-soft shadow-pop p-0 backdrop:bg-ink/40 backdrop:backdrop-blur-sm m-auto w-[min(92vw,460px)] open:animate-pop-in">

    <div class="relative p-7">
        <button type="button"
                data-action="modal#close"
                aria-label="Fermer"
                class="btn btn--secondary btn--icon absolute top-3.5 right-3.5">
            ×
        </button>

        <div class="mb-6">
            <div class="text-[11px] font-semibold tracking-widest uppercase text-ink-soft">Nouveau</div>
            <h2 class="font-serif text-[26px] leading-tight mt-0.5">Un nouveau bingo</h2>
            <p class="font-hand text-[18px] text-ink-soft mt-1.5 -rotate-1">
                <span class="text-accent">✦</span> Une grille à imaginer.
            </p>
        </div>

        {{ form_start(form, { attr: { class: 'flex flex-col gap-4', novalidate: 'novalidate' } }) }}

            <div class="flex flex-col gap-1.5">
                {{ form_label(form.title, null, { label_attr: { class: 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' } }) }}
                {{ form_widget(form.title, { attr: { class: 'px-3.5 py-2.5 rounded-xl bg-cream/60 border border-line-soft focus:outline-none focus:border-accent focus:bg-paper text-ink placeholder:text-ink-faint transition-colors' } }) }}
                {{ form_errors(form.title, { attr: { class: 'text-[12px] text-rose-600' } }) }}
            </div>

            <div class="flex gap-4">
                <div class="flex flex-col gap-1.5">
                    {{ form_label(form.year, null, { label_attr: { class: 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' } }) }}
                    {{ form_widget(form.year, { attr: { class: 'px-3.5 py-2.5 rounded-xl bg-cream/60 border border-line-soft focus:outline-none focus:border-accent focus:bg-paper text-ink placeholder:text-ink-faint transition-colors w-32' } }) }}
                    {{ form_errors(form.year, { attr: { class: 'text-[12px] text-rose-600' } }) }}
                </div>

                <div class="flex flex-col gap-1.5 flex-1">
                    {{ form_label(form.size, null, { label_attr: { class: 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' } }) }}
                    <div class="flex gap-2 size-picker">
                        {% for child in form.size %}
                            <div class="flex-1">
                                {{ form_widget(child, { attr: { class: 'sr-only peer' } }) }}
                                <label for="{{ child.vars.id }}"
                                       class="block text-center px-3.5 py-2.5 rounded-xl bg-cream/60 border border-line-soft text-ink-soft font-semibold cursor-pointer hover:bg-paper hover:text-ink transition-colors peer-checked:bg-accent peer-checked:text-ink peer-checked:border-accent peer-checked:shadow-[0_1px_0_rgba(255,255,255,.6)_inset]">
                                    {{ child.vars.label }}
                                </label>
                            </div>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.size, { attr: { class: 'text-[12px] text-rose-600' } }) }}
                </div>
            </div>

            <div class="flex flex-col gap-1.5">
                {{ form_label(form.items, null, { label_attr: { class: 'text-[11px] font-semibold tracking-widest uppercase text-ink-soft' } }) }}
                {{ form_widget(form.items, { attr: { class: 'px-3.5 py-2.5 rounded-xl bg-cream/60 border border-line-soft focus:outline-none focus:border-accent focus:bg-paper text-ink placeholder:text-ink-faint transition-colors font-sans text-[13px] leading-relaxed resize-y' } }) }}
                {{ form_help(form.items, { help_attr: { class: 'text-[12px] text-ink-soft' } }) }}
                {{ form_errors(form.items, { attr: { class: 'text-[12px] text-rose-600' } }) }}
            </div>

            {{ form_errors(form) }}

            <div class="flex items-center justify-end gap-2.5 mt-2">
                <button type="button" data-action="modal#close" class="btn btn--ghost">
                    Annuler
                </button>
                <button type="submit" class="btn btn--primary">
                    Créer le bingo
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</dialog>
